server {
    listen 80;
    server_name 10.110.10.40;
    #DNS interno do docker
    resolver 127.0.0.11 valid=30s;
    #configuração para o Node-RED
    location /{
        # usar variavel impede que o Nginx trave no boot se o host estiver offline
        set $upstream_noderd http://node-red:1880;
        # 1. Permite o acesso vindo apenas da sua rede de trabalho (MESH)
        allow 10.110.10.0/24; 
        # 2. Bloqueia TODO o resto (inclusive o Wi-Fi do TI)
        deny all;
        #Silencia logs de erro desnecessários
        error_log /dev/null crit;

        proxy_set_header Host $host;
        proxy_pass http://node-red:1880/;
        proxy_set_header X-Real-IP $remote_addr;
        # Dica Sênior: Node-RED usa WebSockets. Adicione estas linhas para não cair a conexão:
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
    }

    # Configuração para o Grafana (se quiser usar o sub-caminho /grafana)
    location /grafana/ {
        proxy_pass http://grafana:3000;
        proxy_set_header Host $host;
    }

    #Configuraçao do influxDB
    location /influxdb/ {
        # Remove o prefixo /influxdb antes de enviar ao InfluxDB
        rewrite ^/influxdb/(.*) /$1 break;
        proxy_pass http://influxdb:8086;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    
    }
}
